# ──────────────────────────────────────────────────────────────────────────
# RefundWise — environment variables
# Copy this file to `.env.local` and fill in at least ONE LLM key.
# Everything here is on a FREE tier. No paid services required.
# ──────────────────────────────────────────────────────────────────────────

# ---- LLM (free tiers; at least ONE key required to run the agent) ----
# Primary: Google Gemini — free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Fallback: Groq — free key from https://console.groq.com/keys
# If Gemini rate-limits/errors, the agent transparently falls back to Groq.
GROQ_API_KEY=

# Models (defaults are fine; both on free tiers)
GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.3-70b-versatile
# Which provider to try first: "gemini" or "groq"
LLM_PRIMARY=gemini

# ---- Agent / policy knobs ----
AGENT_MAX_ITERATIONS=10
# Refunds at or above this dollar amount must be escalated to a human (never auto-approved).
HIGH_VALUE_THRESHOLD=500

# ---- Database ----
# Local dev: SQLite file (default). Leave the TURSO_* vars empty.
DATABASE_URL=file:./dev.db
# Deploy on Vercel using Turso's FREE tier — set BOTH to switch the runtime to Turso:
#   1. Create a free DB:  turso db create refundwise
#   2. URL:               turso db show refundwise --url
#   3. Token:             turso db tokens create refundwise
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ---- Voice (bonus; browser Web Speech API — no keys, no cost) ----
NEXT_PUBLIC_VOICE_ENABLED=false
